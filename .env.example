# Copy to .env (gitignored) and fill in. Never commit real values.

# --- App ---
APP_ENV=local
LOG_LEVEL=info
PILOT_MINUTES_CAP=300
FEATURE_SMS_ENABLED=false          # keep OFF until Twilio is funded (Phase 7)

# --- Supabase (Phase 1) ---
SUPABASE_URL=
# server-side only, never expose client-side
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# --- Retell (Phase 3) ---
RETELL_API_KEY=
# used to verify webhook signatures
RETELL_WEBHOOK_SECRET=

# --- Cal.com (Phase 4) — free tier ---
# Settings -> Developer -> API keys. Starts cal_live_...
CALCOM_API_KEY=
# The numeric id of the "Property Tour (30 min)" event type — the number in the URL when
# you open that event type (…/event-types/1234567). Not the slug.
# Per-client calendars override this via clients.cal_event_type_id.
# Leave blank and tours fall back to generated business-hours slots (no calendar writes).
CALCOM_EVENT_TYPE_ID=

# --- Resend (Phase 4) — free tier ---
RESEND_API_KEY=
# Free tier, no verified domain: this MUST be onboarding@resend.dev, and Resend will only
# deliver to the address you signed up with — so set clients.notify_email to that address
# for testing. A real from-address needs a verified domain (Phase 6/7).
FROM_EMAIL=onboarding@resend.dev

# --- Twilio (DEFERRED until Phase 7 — leave blank for now) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
