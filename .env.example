# Copy to .env (gitignored) and fill in. Never commit real values.

# --- App ---
APP_ENV=local
LOG_LEVEL=info
PILOT_MINUTES_CAP=300
FEATURE_SMS_ENABLED=false          # keep OFF until Twilio is funded (Phase 7)

# --- Supabase (Phase 1) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=         # server-side only, never expose client-side
DATABASE_URL=

# --- Retell (Phase 3) ---
RETELL_API_KEY=
RETELL_WEBHOOK_SECRET=             # used to verify webhook signatures

# --- Cal.com (Phase 4) ---
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=

# --- Resend (Phase 4) ---
RESEND_API_KEY=
FROM_EMAIL=

# --- Twilio (DEFERRED until Phase 7 — leave blank for now) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
